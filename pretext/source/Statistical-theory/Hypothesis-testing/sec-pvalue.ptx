  <xi:include href="./The-p-value-of-a-test/Using-R-Instat--Interpreting-p-values/sec-using-rinstat-interpreting-pvalues.ptx" />

  <conclusion>
    <table xml:id="tab-pvaltable">
    <title>Conventional p-value thresholds</title>

    <tabular>
    <row header="yes">
      <cell>Usual notation</cell>
      <cell>English translation</cell>
      <cell>The null is?</cell>
    </row>

    <row>
      <cell>p &gt; .05</cell>
      <cell>The test wasn't significant</cell>
      <cell>Retained</cell>
    </row>

    <row>
      <cell>p &lt; .05</cell>
      <cell>The test was significant at <m>\alpha = 0.05</m>, but not at <m>\alpha = 0.01</m> or <m>\alpha = 0.001</m></cell>
      <cell>Rejected</cell>
    </row>

    <row>
      <cell>p &lt; .01</cell>
      <cell>The test was significant at <m>\alpha = 0.05</m> and <m>\alpha = 0.01</m>, but not at <m>\alpha = 0.001</m></cell>
      <cell>Rejected</cell>
    </row>

    <row>
      <cell>p &lt; .001</cell>
      <cell>The test was significant at all levels</cell>
      <cell>Rejected</cell>
    </row>
    </tabular>
    </table>
  </conclusion>
</section>


